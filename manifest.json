{
  "name": "SimpleRSS",
  "description": "A Simple RSS Reader Extension created by Paul Surrette",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "images/rss.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ]
}