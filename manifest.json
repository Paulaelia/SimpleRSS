{
  "name": "SimpleRSS",
  "description": "A Simple RSS Reader Extension created by Paul Surrette",
  "version": "1.3",
  "manifest_version": 3,
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "images/rss.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "https://*/*"
  ]
}